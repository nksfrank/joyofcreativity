---
import SiteLayout from "@/components/layouts/SiteLayout.astro";
import { getAllProducts, getProductDetailsByProductId } from "@/libs/product";
import { resolveColourNav } from "@/libs/product.utils";

export function getStaticPaths() {
  return ["sweaters"].map((slug) => ({ params: { id: "1", slug } }));
}

const products = getAllProducts().map((product) => ({
  id: product.id,
  name: getProductDetailsByProductId(product.id)[0]?.details.name ?? product.id,
  // isCurrent is irrelevant on the listing; we only need each colour's label + href.
  variants: resolveColourNav(product.id, ""),
}));
---

<SiteLayout title="Sweaters">
  <h1>Sweaters</h1>
  <ul>
    {
      products.map((product) => (
        <li data-testid="product-card">
          <h2 data-testid="product-card-title">{product.name}</h2>
          <ul data-testid="product-card-variants">
            {product.variants.map((variant) => (
              <li>
                <a href={variant.href}>{variant.colourName}</a>
              </li>
            ))}
          </ul>
        </li>
      ))
    }
  </ul>
</SiteLayout>
