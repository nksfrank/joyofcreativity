---
import Configurator from "@/components/Configurator.tsx";
import SiteLayout from "@/components/layouts/SiteLayout.astro";
import { getLocale } from "@/i18n/runtime";
import {
  getAllProducts,
  getProductById,
  getProductDetailsByProductId,
} from "@/libs/product";
import { resolveColourNav, resolveColourPages } from "@/libs/product.utils";
import { assert } from "@/utils/assert";

export function getStaticPaths() {
  return getAllProducts().flatMap((product) =>
    resolveColourPages(product.id).map((page) => ({
      params: { id: page.id, slug: page.slug },
      props: { page },
    })),
  );
}

const { page } = Astro.props;
const product = getProductById(page.productId);
assert(product, `Product ${page.productId} not found`);

const colourNav = resolveColourNav(page.productId, page.colorId);
const productName =
  getProductDetailsByProductId(page.productId)[0]?.details.name ?? page.name;
const locale = getLocale();
---

<SiteLayout title={page.name}>
  <article>
    {page.image && <img src={page.image} alt={page.name} />}
    <h1>{page.name}</h1>
    <p>{page.description}</p>

    <p data-testid="product-colour">Colour: {page.colourName}</p>

    {
      /* A sole colour has nowhere to switch to, so no switcher renders (ADR-0010). */
      colourNav.length > 1 && (
        <nav aria-label="Colour">
          <ul>
            {colourNav.map((colour) => (
              <li>
                <a
                  href={colour.href}
                  data-testid="colour-option"
                  aria-current={colour.isCurrent ? "true" : undefined}
                >
                  {colour.colourName}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <Configurator
      client:load
      definition={product}
      colorId={page.colorId}
      colourName={page.colourName}
      productName={productName}
      locale={locale}
    />
  </article>
</SiteLayout>
