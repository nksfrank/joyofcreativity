{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**/src/**/*",
      "**/.vscode/**/*",
      "!**/dist",
      "!worker-configuration.d.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.astro"],
      "linter": {
        "rules": {
          "style": {
            "useConst": "off",
            "useImportType": "off"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["**/src/libs/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/server",
                      "**/server/**",
                      "**/actions",
                      "**/actions/**",
                      "**/components",
                      "**/components/**",
                      "**/stores",
                      "**/stores/**"
                    ],
                    "message": "src/libs/ is the isomorphic domain core (ADR-0013) and must not import from server/, actions/, components/, or stores/. A need for this is the smell that server-only concern has leaked into the core — move the shared code into libs/ or utils/, or invert the dependency."
                  },
                  {
                    "group": ["stripe", "stripe/**"],
                    "message": "src/libs/ is the isomorphic domain core (ADR-0013) and must never import the Stripe SDK — it is server-only and would drag Stripe (and secrets) toward the client bundle. Server code talks to Stripe through the adapter port in src/server/stripe.ts (issue #61)."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "**/src/components/**",
        "**/src/stores/**",
        "**/src/pages/**",
        "!**/src/pages/api/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "**/server",
                      "**/server/**",
                      "**/actions",
                      "**/actions/**"
                    ],
                    "message": "Client-shipped code must not import from src/server/ or src/actions/ directly (ADR-0014): it would pull Effect's fixed bundle cost into the browser. Call server logic through the `astro:actions` module (`import { actions } from 'astro:actions'`)."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
