{
  "name": "joyofcreativity-astro",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "i18n": "paraglide-js compile --project ./project.inlang --outdir ./src/i18n",
    "prebuild": "npm run i18n",
    "build": " astro build",
    "preview": "npm run build && wrangler dev",
    "pretest": "npm run i18n",
    "test": "vitest",
    "test:e2e": "playwright test",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check && astro check",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "14.1.1",
    "astro": "7.0.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@biomejs/biome": "2.5.2",
    "@inlang/cli": "3.0.0",
    "@inlang/paraglide-js": "2.20.2",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "wrangler": "4.107.0"
  }
}
