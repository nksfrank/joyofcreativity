{
  "name": "joyofcreativity",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "npm run cf-typegen",
    "dev": "astro dev",
    "i18n": "paraglide-js compile --project ./project.inlang --outdir ./src/i18n",
    "prebuild": "npm run i18n && npm run cf-typegen",
    "build": " astro build",
    "preview": "npm run build && wrangler dev",
    "pretest": "npm run i18n && npm run cf-typegen",
    "test": "vitest",
    "test:e2e": "playwright test",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check && astro check",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply joyofcreativity --local",
    "db:migrate:remote": "wrangler d1 migrations apply joyofcreativity --remote",
    "db:studio": "drizzle-kit studio",
    "db:seed-sync": "node --experimental-strip-types scripts/seed-sync.ts",
    "db:seed-sync:local": "node --experimental-strip-types scripts/seed-sync.ts > drizzle/seed-sync.sql && wrangler d1 execute joyofcreativity --local --file drizzle/seed-sync.sql",
    "db:seed-sync:remote": "node --experimental-strip-types scripts/seed-sync.ts > drizzle/seed-sync.sql && wrangler d1 execute joyofcreativity --remote --file drizzle/seed-sync.sql",
    "deploy": "npm run build && npm run db:migrate:remote && npm run db:seed-sync:remote && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "14.1.1",
    "@astrojs/preact": "6.0.1",
    "@nanostores/persistent": "1.3.4",
    "@nanostores/preact": "1.1.0",
    "@preact/signals": "2.9.3",
    "astro": "7.0.6",
    "drizzle-orm": "0.45.2",
    "effect": "3.22.0",
    "nanostores": "1.4.0",
    "preact": "10.29.7",
    "stripe": "22.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@biomejs/biome": "2.5.2",
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@inlang/cli": "3.0.0",
    "@inlang/paraglide-js": "2.20.2",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.0",
    "drizzle-kit": "0.31.10",
    "schema-dts": "2.0.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "wrangler": "4.107.0"
  }
}
